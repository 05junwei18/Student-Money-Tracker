<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Money Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h2 class="text-center mb-4">Student Money Tracker</h2>

        <div class="row text-center mb-4">
            <div class="col-6">
                <div class="card p-3 bg-success text-white">
                    <h5>Total Income</h5>
                    <h3>$<%= totalIncome %></h3>
                </div>
            </div>
            <div class="col-6">
                <div class="card p-3 bg-danger text-white">
                    <h5>Total Expenses</h5>
                    <h3>$<%= totalExpense %></h3>
                </div>
            </div>
        </div>

        <div class="row text-center mb-4">
            <div class="col-6">
                <div class="card p-3 bg-success text-white">
                    <h5>Total Overall</h5>
                    <h3>$<%= totalOverall %></h3>
                </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card p-3">
                    <h4>Add Transaction</h4>
                    <form action="/addTransaction" method="POST">
                        <select name="type" class="form-select mb-2" required>
                            <option value="income">Income</option>
                            <option value="expense">Expense</option>
                        </select>
                        <input type="text" name="description" placeholder="Description" class="form-control mb-2" required>
                        <input type="number" name="amount" placeholder="Amount" class="form-control mb-2" step="1.00" required>
                        <input type="date" name="date" class="form-control mb-2" required>
                        <button type="submit" class="btn btn-primary w-100">Add</button>
                    </form>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card p-3">
                    <h4>History</h4>
                    <ul class="list-group">
                        <% transactions.forEach(t => { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong><%= t.description %></strong> (<%= t.date %>)
                                    <span class="badge <%= t.type === 'income' ? 'bg-success' : 'bg-danger' %> ms-2">
                                        <%= t.type.toUpperCase() %>
                                    </span>
                                </div>
                                <div>
                                    $<%= t.amount.toFixed(2) %>
                                    <form action="/deleteTransaction/<%= t.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-2">Delete</button>
                                    </form>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</body>
</html>